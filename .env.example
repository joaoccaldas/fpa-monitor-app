# FP&A Monitor Configuration
# Copy this file to .env and update with your actual values

# Flask Configuration
SECRET_KEY=your-secret-key-change-in-production
FLASK_ENV=development
MAX_CONTENT_LENGTH=16777216

# Anomaly Detection Settings
ANOMALY_THRESHOLD=2.5
LOOKBACK_DAYS=30

# Alert Configuration
ALERT_EMAIL=your-email@example.com

# LLM Configuration
LLM_PROVIDER=perplexity
LLM_API_KEY=your-llm-api-key
LLM_BASE_URL=https://api.perplexity.ai
LLM_MODEL=llama-3.1-sonar-small-128k-online

# Sprint 1: Real-Time KPI Alert Configuration
# Alert Check Interval (in seconds)
ALERT_CHECK_INTERVAL=300

# SendGrid Email Notifications
SENDGRID_API_KEY=your-sendgrid-api-key
SENDGRID_FROM_EMAIL=alerts@yourdomain.com

# Slack Notifications
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_CHANNEL=#alerts

# Data Source Configuration (optional)
# DATABASE_URL=postgresql://user:password@localhost:5432/fpa_db
# API_KEY=your_api_key_here
# API_ENDPOINT=https://api.example.com/metrics

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=fpa_monitor.log
